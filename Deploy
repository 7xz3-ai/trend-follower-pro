#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# TREND_FOLLOWER_PRO — one-shot deploy script
# Usage: bash deploy.sh
# Requires: git repo already cloned, GITHUB remote set, files in ./public/
# ─────────────────────────────────────────────────────────────────────────────
set -e

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║   TREND_FOLLOWER_PRO  ·  Deploy Script       ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# ── Check we're in a git repo ─────────────────────────────────────────────────
if [ ! -d ".git" ]; then
  echo "❌  Not a git repo. cd into your trend-follower-pro folder first."
  exit 1
fi

# ── Copy output files into repo ───────────────────────────────────────────────
echo "📁  Copying files..."
cp index.js ./index.js 2>/dev/null || true
mkdir -p public
cp index.html ./public/index.html 2>/dev/null || true

# Make sure package.json is correct (no "type":"module")
if [ -f "package.json" ]; then
  node -e "
    const fs=require('fs');
    const pkg=JSON.parse(fs.readFileSync('package.json','utf8'));
    delete pkg.type;
    pkg.dependencies = pkg.dependencies || {};
    pkg.dependencies.express = pkg.dependencies.express || '^4.18.2';
    pkg.dependencies.ws = pkg.dependencies.ws || '^8.16.0';
    fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2));
    console.log('✅  package.json verified');
  "
else
  echo '{"name":"trend-follower-pro","version":"1.0.0","dependencies":{"express":"^4.18.2","ws":"^8.16.0"}}' > package.json
  echo "✅  package.json created"
fi

# Make sure railway.json is correct
cat > railway.json << 'RAILWAY'
{
  "build": {
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "node index.js"
  }
}
RAILWAY
echo "✅  railway.json verified"

# ── Git commit & push ─────────────────────────────────────────────────────────
echo ""
echo "📤  Committing & pushing to GitHub..."
git add -A
git commit -m "feat: 1-month history panel, multi-entry signals, mobile layout, demo mode

- HistoryPanel: chart / heatmap / table views for 7/14/30 day lookbacks
- /api/history/:symbol  — paginated single-symbol bars (up to 10k)
- /api/history/multi/snapshot — all 20 symbols in parallel for heatmap
- 5 entry strategies: PULLBACK / BREAKOUT / BOUNCE / CROSS / SCALP
- Auto-engine now enters multiple trades per cycle (up to maxPositions)
- Lower default thresholds: minStrength 45%, cooldown 15s, maxHold 180s
- Mobile auto-detect with bottom nav (6 tabs incl. History)
- Demo mode: tick replay + fast-forward using yesterday's real bars
- Equity curve, analytics, risk alerts" || echo "ℹ️  Nothing new to commit"

git push origin main || git push origin master
echo ""
echo "✅  Pushed! Railway will auto-redeploy in ~60s."
echo ""
echo "🔗  Check: https://trend-follower-pro-production.up.railway.app/health"
echo "🔗  App:   https://trend-follower-pro-production.up.railway.app"
echo ""
