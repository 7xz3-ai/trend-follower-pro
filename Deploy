#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# TREND_FOLLOWER_PRO — one-shot deploy
# Run from inside your cloned GitHub repo folder:
#   bash deploy.sh
# ─────────────────────────────────────────────────────────────────────────────
set -e

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║   TREND_FOLLOWER_PRO  ·  Deploy Script       ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

if [ ! -d ".git" ]; then echo "❌  Run from inside your repo folder."; exit 1; fi

echo "📁  Copying files..."
cp "$(dirname "$0")/index.js" ./index.js
mkdir -p public
cp "$(dirname "$0")/index.html" ./public/index.html

# Ensure package.json is correct
node -e "
  const fs=require('fs');
  let pkg={};
  try{pkg=JSON.parse(fs.readFileSync('package.json','utf8'));}catch(e){}
  delete pkg.type;
  pkg.name=pkg.name||'trend-follower-pro';
  pkg.version=pkg.version||'1.0.0';
  pkg.dependencies=pkg.dependencies||{};
  pkg.dependencies.express='^4.18.2';
  pkg.dependencies.ws='^8.16.0';
  fs.writeFileSync('package.json',JSON.stringify(pkg,null,2));
  console.log('✅  package.json OK');
"

# Ensure railway.json is correct
cat > railway.json << 'RAILWAY'
{
  "build":  { "buildCommand": "npm install" },
  "deploy": { "startCommand": "node index.js" }
}
RAILWAY
echo "✅  railway.json OK"

echo ""
echo "📤  Committing & pushing..."
git add -A
git commit -m "feat: full auto-demo engine, signal v4, all-symbol simulation

DEMO MODE — fully automatic:
- Simulates a full trading day across all 20 symbols simultaneously
- Each symbol gets its own correlated intraday price path (bull/bear market bias)
- Auto-trade checkbox: engine enters trades without any manual clicks
- Real bars fetched from Alpaca for previous trading day (falls back to synthetic)
- Chart symbol picker — switch which stock you watch mid-replay
- Fast-forward (55ms/bar) or real-time (380ms/bar) modes
- Progress bar, pause/resume/stop controls

SIGNAL ENGINE v4:
- Persistent EMA state (ema5/9/21/50/200) — proper Wilder smoothing, no random jumps
- Persistent RSI via avgGain/avgLoss smoothing — realistic RSI that evolves tick by tick
- 5 strategies: PULLBACK / BREAKOUT / BOUNCE / CROSS / SCALP
- Higher base scores — BUY fires more readily, more trades per day
- Per-strategy SL/TP multipliers, tighter breakeven (0.5 ATR)

AUTO-ENGINE:
- Works in both live/sim AND demo mode (separate loops)
- Demo uses relaxed thresholds (minStrength-5pp, minRR 1.0) for visible activity
- Enters multiple candidates per scan cycle
- History panel: 7/14/30D chart + heatmap + table for all 20 symbols" || echo "ℹ️  Nothing new to commit"

git push origin main || git push origin master

echo ""
echo "✅  Deployed! Railway rebuilds in ~60s."
echo ""
echo "   App:    https://trend-follower-pro-production.up.railway.app"
echo "   Health: https://trend-follower-pro-production.up.railway.app/health"
echo ""
